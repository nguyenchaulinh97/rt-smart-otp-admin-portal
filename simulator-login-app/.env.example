# ── Auth provider ────────────────────────────────────
# "mock"  → dùng mock API routes (/api/mock/*)  [mặc định]
# "http"  → gọi API thật qua httpAuthAdapter
NEXT_PUBLIC_AUTH_PROVIDER=mock

# ── Gọi trực tiếp backend (khuyến nghị) ─────────────
# NEXT_PUBLIC_AUTH_PROVIDER=http
# NEXT_PUBLIC_AUTH_API_BASE_URL=http://159.89.203.207:8082
# NEXT_PUBLIC_AUTH_LOGIN_PATH=/api/v1/auth/login
# NEXT_PUBLIC_AUTH_LOGIN_CONTENT_TYPE=text/plain

# ── Verify / Resend (vẫn mock trừ khi có endpoint thật) ──
# NEXT_PUBLIC_AUTH_VERIFY_PATH=/api/mock/auth/verify
# NEXT_PUBLIC_AUTH_RESEND_PATH=/api/mock/auth/resend
